<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="create_inventory_transfer_wizard_action" model="ir.actions.act_window">
        <field name="name">Create Inventory Transfer</field>
        <field name="res_model">create.inventory.transfer.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="view_create_inventory_transfer_wizard" model="ir.ui.view">
        <field name="name">create.inventory.transfer.wizard.form</field>
        <field name="model">create.inventory.transfer.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Inventory Transfer">
                <group>
                    <field name="picking_type_id" options="{'no_create': True}"/>
                    <field name="warehouse_id"/>
                </group>
                <notebook>
                    <page>
                        <field name="line_ids" options="{'no_create': True}" create="false">
                            <list create="0" editable="top">
                                <field name="product_id"/>
                                <field name="boq_line_id"/>
                                <field name="project_warehouse_id"/>
                                <field name="product_uom_qty"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button name="action_create_transfer" string="Create Transfer" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="server_action_create_transfer_wizard" model="ir.actions.server">
        <field name="name">Open Create Inventory Transfer Wizard</field>
        <field name="model_id" ref="model_task_product_link"/>
        <field name="binding_model_id" ref="model_task_product_link"/>
        <field name="state">code</field>
        <field name="code">
            action = records.action_open_transfer_wizard()
        </field>
    </record>


    <record id="action_picking_tree_all" model="ir.actions.act_window">
        <field name="name">All Transfers</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
    </record>


</odoo>