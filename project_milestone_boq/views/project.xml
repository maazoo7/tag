    <record id="action_project_milestone" model="ir.actions.act_window">
        <field name="name">Project Milestones</field>
        <field name="res_model">project.milestone</field>
        <field name="view_mode">list,kanban,form</field>
<!--        <field name="view_id" ref="view_project_milestone_gantt_custom"/>-->

    </record>


    <record id="view_project_milestone_form" model="ir.ui.view">
        <field name="name">project.milestone.form</field>
        <field name="model">project.milestone</field>
        <field name="inherit_id" ref="project.project_milestone_view_form"/>
        <field name="arch" type="xml">
            <form position="replace">
                <form>
                    <header>
                        <button name="create_invoice"
                                string="Create Invoice"
                                type="object"
                                class="btn-primary"
                                invisible="progress_completion != 100 or not sale_order_id or invoice_generated"/>
                        <field name="invoice_status" widget="badge"
                               decoration-success="invoice_generated == True"
                               decoration-info="progress >= 100 and invoice_generated == False"
                               decoration-warning="progress &lt; 100"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button"
                                    type="object"
                                    name="action_view_tasks"
                                    icon="fa-tasks"
                                    invisible="not task_ids">
                                <field name="task_ids" widget="statinfo" string="Tasks"/>
                            </button>
                        </div>

                        <div class="oe_title">
                            <label for="name" string="Milestone Name"/>
                            <h1>
                                <field name="name" placeholder="e.g. Phase 1 - Development"/>
                            </h1>
                        </div>

                        <group>
                            <group string="Project Information">
                                <field name="project_id" required="1"/>
                                <field name="sale_order_id"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="invoice_status"/>
                            </group>
                            <group string="Progress &amp; Dates">
                                <field name="progress" widget="progressbar"/>
                                <field name="progress_completion" readonly="1"/>
                                <field name="start_date" readonly="1"/>
                                <field name="end_date" readonly="1"/>
                            </group>
                        </group>

                        <group>
                            <group string="Financial Information">
                                <field name="total_amount" widget="monetary"/>
                                <field name="percentage" invisible="1"/>
                            </group>
                            <group string="Invoice Status">
                                <field name="invoice_generated" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Tasks" name="tasks">
                                <field name="task_ids" readonly="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="stage_id"/>
                                        <field name="user_ids" widget="many2many_avatar_user"/>
<!--                                        <field name="planned_date_begin"/>-->
                                        <field name="date_deadline"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Details" name="details">
                                <group>
                                    <field name="id" readonly="1"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </form>
        </field>
    </record>

    <record id="view_project_milestone_list_view" model="ir.ui.view">
        <field name="name">project.milestone.list.view</field>
        <field name="model">project.milestone</field>
        <field name="inherit_id" ref="sale_project.project_milestone_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="progress" widget="progressbar"/>
                <field name="progress_completion"/>
                <field name="percentage"/>
                <field name="invoice_status"/>
                <!--                <field name="invoice_generated"/>-->
                <field name="total_amount"/>
                <field name="sale_order_id"/>
                <button name="create_invoice"
                        string="Create Invoice"
                        type="object"
                        icon="fa-file-invoice-dollar"
                        invisible="invoice_status not in ['Ready to Invoice']"/>
            </xpath>
            <xpath expr="//field[@name='sale_line_id']" position="replace">
            </xpath>
            <xpath expr="//field[@name='quantity_percentage']" position="replace">
            </xpath>
            <xpath expr="//field[@name='deadline']" position="replace">
            </xpath>
            <xpath expr="//field[@name='is_reached']" position="replace">
            </xpath>
        </field>
    </record>

    <!-- Create PR -->
    <record id="action_create_pr_from_task_product_link" model="ir.actions.server">
        <field name="name">Create PR</field>
        <field name="model_id" ref="model_task_product_link"/>
        <field name="binding_model_id" ref="model_task_product_link"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            action = records.action_create_pr()
        </field>
    </record>

    <record id="view_task_product_link_tree_inherit" model="ir.ui.view">
        <field name="name">task.product.link.tree.inherit</field>
        <field name="model">task.product.link</field>
        <field name="inherit_id" ref="project_milestone_boq.view_task_product_link_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//list" position="inside">
                <header>
                    <button name="action_open_transfer_wizard"
                            type="object"
                            string="Create Inventory Transfer"
                            class="oe_highlight"/>

                    <button name="action_create_pr"
                            type="object"
                            string="Create PR"
                            class="oe_highlight"/>

                </header>
            </xpath>
        </field>
    </record>


