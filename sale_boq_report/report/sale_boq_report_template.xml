<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_sale_boq_document">
        <t t-call="web.external_layout">
            <t t-set="doc" t-value="doc"/>
            <main>
                <div class="page">

                    <!-- TITLE -->
                    <div style="text-align:center;margin-bottom:10px;">
                        <div style="font-weight:800;font-size:13px;letter-spacing:1px;">BILL OF QUANTITIES</div>
                        <div style="font-size:11px;">SUMMARY OF COSTS</div>
                    </div>

                    <!-- PROJECT INFO -->
                    <table style="width:100%;font-size:10px;margin-bottom:10px;border-collapse:collapse;">
                        <tr>
                            <td style="font-weight:700;width:22%;padding:1px 3px;">Name of Project:</td>
                            <td style="padding:1px 3px;"><t t-esc="doc.name"/></td>
                        </tr>
                        <tr>
                            <td style="font-weight:700;padding:1px 3px;">Location:</td>
                            <td style="padding:1px 3px;">
                                <t t-esc="', '.join(filter(None,[
                                    doc.partner_id.street or '',
                                    doc.partner_id.city or '',
                                    doc.partner_id.state_id.name if doc.partner_id.state_id else '',
                                    doc.partner_id.country_id.name if doc.partner_id.country_id else ''
                                ]))"/>
                            </td>
                        </tr>
                    </table>

                    <!-- MAIN BOQ TABLE -->
                    <t t-set="boq" t-value="doc._get_boq_summary()"/>

                    <table style="width:100%;border-collapse:collapse;font-size:9px;">
                        <thead>
                            <tr style="text-align:center;font-weight:700;">
                                <th style="border:1px solid #000;padding:4px;width:9%;">No. Item</th>
                                <th style="border:1px solid #000;padding:4px;text-align:left;width:32%;">Description</th>
                                <th style="border:1px solid #000;padding:4px;width:15%;">Tools and Equipment</th>
                                <th style="border:1px solid #000;padding:4px;width:15%;">Cost of Materials</th>
                                <th style="border:1px solid #000;padding:4px;width:15%;">Labor Cost</th>
                                <th style="border:1px solid #000;padding:4px;width:14%;">Total Cost</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="boq['rows']" t-as="row">

                                <!-- SECTION HEADER (no cost columns) -->
                                <tr t-if="row['is_section']">
                                    <td style="border:1px solid #ccc;padding:2px 4px;font-weight:700;text-align:center;">
                                        <t t-esc="row['number']"/>
                                    </td>
                                    <td colspan="5" style="border:1px solid #ccc;padding:2px 6px;font-weight:700;">
                                        <t t-esc="row['name']"/>
                                    </td>
                                </tr>

                                <!-- COST ROW -->
                                <tr t-if="not row['is_section']">
                                    <td style="border:1px solid #ccc;padding:2px 4px;text-align:center;">
                                        <t t-esc="row['number']"/>
                                    </td>
                                    <td style="border:1px solid #ccc;padding:2px 6px;">
                                        <t t-esc="row['name']"/>
                                    </td>

                                    <!-- Tools and Equipment -->
                                    <td style="border:1px solid #ccc;padding:2px 4px;text-align:right;">
                                        <t t-if="row['equipment'] is not None">
                                            <span style="float:left;">P</span>
                                            <t t-if="row['equipment'] != 0">
                                                <t t-esc="'{:,.2f}'.format(row['equipment'])"/>
                                            </t>
                                            <t t-if="row['equipment'] == 0">&#8211;</t>
                                        </t>
                                    </td>

                                    <!-- Cost of Materials -->
                                    <td style="border:1px solid #ccc;padding:2px 4px;text-align:right;">
                                        <t t-if="row['material'] is not None">
                                            <span style="float:left;">P</span>
                                            <t t-if="row['material'] != 0">
                                                <t t-esc="'{:,.2f}'.format(row['material'])"/>
                                            </t>
                                            <t t-if="row['material'] == 0">&#8211;</t>
                                        </t>
                                    </td>

                                    <!-- Labor Cost -->
                                    <td style="border:1px solid #ccc;padding:2px 4px;text-align:right;">
                                        <t t-if="row['labour'] is not None">
                                            <span style="float:left;">P</span>
                                            <t t-if="row['labour'] != 0">
                                                <t t-esc="'{:,.2f}'.format(row['labour'])"/>
                                            </t>
                                            <t t-if="row['labour'] == 0">&#8211;</t>
                                        </t>
                                    </td>

                                    <!-- Total Cost -->
                                    <td style="border:1px solid #ccc;padding:2px 4px;text-align:right;">
                                        <t t-if="row['total'] is not None">
                                            <span style="float:left;">P</span>
                                            <t t-if="row['total'] != 0">
                                                <t t-esc="'{:,.2f}'.format(row['total'])"/>
                                            </t>
                                            <t t-if="row['total'] == 0">&#8211;</t>
                                        </t>
                                    </td>
                                </tr>

                            </t>

                            <!-- TOTAL ITEM COST -->
                            <tr style="font-weight:800;background-color:#f5d76e;">
                                <td style="border:1px solid #999;padding:4px;"></td>
                                <td style="border:1px solid #999;padding:4px 6px;">TOTAL ITEM COST</td>
                                <td style="border:1px solid #999;padding:4px;text-align:right;">
                                    <t t-esc="'{:,.2f}'.format(boq['total_equipment'])"/>
                                </td>
                                <td style="border:1px solid #999;padding:4px;text-align:right;">
                                    <t t-esc="'{:,.2f}'.format(boq['total_material'])"/>
                                </td>
                                <td style="border:1px solid #999;padding:4px;text-align:right;">
                                    <t t-esc="'{:,.2f}'.format(boq['total_labour'])"/>
                                </td>
                                <td style="border:1px solid #999;padding:4px;text-align:right;">
                                    <t t-esc="'{:,.2f}'.format(boq['grand_total'])"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- SUMMARY BLOCK -->
                    <table style="width:100%;border-collapse:collapse;font-size:9px;margin-top:4px;">
                        <tr>
                            <td style="border:1px solid #ccc;padding:3px 6px;width:55%;font-weight:700;">Description</td>
                            <td colspan="2" style="border:1px solid #ccc;padding:3px 6px;font-weight:700;text-align:center;">Total Item Cost</td>
                        </tr>
                        <tr>
                            <td style="border:1px solid #ccc;padding:2px 6px;">1.0 Total Material Cost</td>
                            <td style="border:1px solid #ccc;padding:2px 4px;text-align:center;width:4%;">P</td>
                            <td style="border:1px solid #ccc;padding:2px 8px;text-align:right;">
                                <t t-esc="'{:,.2f}'.format(boq['total_material'])"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="border:1px solid #ccc;padding:2px 6px;">2.0 Total Labor Cost</td>
                            <td style="border:1px solid #ccc;padding:2px 4px;text-align:center;">P</td>
                            <td style="border:1px solid #ccc;padding:2px 8px;text-align:right;">
                                <t t-esc="'{:,.2f}'.format(boq['total_labour'])"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="border:1px solid #ccc;padding:2px 6px;">3.0 Total Equipment Cost</td>
                            <td style="border:1px solid #ccc;padding:2px 4px;text-align:center;">P</td>
                            <td style="border:1px solid #ccc;padding:2px 8px;text-align:right;">
                                <t t-esc="'{:,.2f}'.format(boq['total_equipment'])"/>
                            </td>
                        </tr>

                        <!-- TOTAL DIRECT COST -->
                        <tr style="font-weight:800;">
                            <td style="border:1px solid #999;padding:3px 6px;text-align:right;">
                                TOTAL DIRECT COST:
                            </td>
                            <td style="border:1px solid #999;padding:3px 4px;text-align:center;">P</td>
                            <td style="border:1px solid #999;padding:3px 8px;text-align:right;background-color:#f5d76e;">
                                <t t-esc="'{:,.2f}'.format(boq['grand_total'])"/>
                            </td>
                        </tr>

                        <!-- CONTRACTOR'S PROFIT -->
                        <tr>
                            <td style="border:1px solid #ccc;padding:2px 6px;">
                                CONTRACTOR'S PROFIT (<t t-esc="'{:g}'.format(boq['profit_rate'])"/>% TDC) - Excluding Permits and Licensing
                            </td>
                            <td style="border:1px solid #ccc;padding:2px 4px;text-align:center;">P</td>
                            <td style="border:1px solid #ccc;padding:2px 8px;text-align:right;">
                                <t t-esc="'{:,.2f}'.format(boq['profit_amount'])"/>
                            </td>
                        </tr>

                        <!-- OCM -->
                        <tr>
                            <td style="border:1px solid #ccc;padding:2px 6px;">
                                OCM (<t t-esc="'{:g}'.format(boq['ocm_rate'])"/>% TDC) - Excluding Permits and Licensing &amp; Occupational Safety and Health
                            </td>
                            <td style="border:1px solid #ccc;padding:2px 4px;text-align:center;">P</td>
                            <td style="border:1px solid #ccc;padding:2px 8px;text-align:right;">
                                <t t-esc="'{:,.2f}'.format(boq['ocm_amount'])"/>
                            </td>
                        </tr>

                        <!-- VAT -->
                        <tr>
                            <td style="border:1px solid #ccc;padding:2px 6px;">
                                VAT (12% TDC+CP+OCM)
                            </td>
                            <td style="border:1px solid #ccc;padding:2px 4px;text-align:center;">P</td>
                            <td style="border:1px solid #ccc;padding:2px 8px;text-align:right;">
                                <t t-esc="'{:,.2f}'.format(boq['vat_amount'])"/>
                            </td>
                        </tr>

                        <!-- TOTAL CONSTRUCTION COST -->
                        <tr style="font-weight:800;background-color:#f5d76e;">
                            <td style="border:1px solid #999;padding:3px 6px;text-align:right;">
                                TOTAL CONSTRUCTION COST:
                            </td>
                            <td style="border:1px solid #999;padding:3px 4px;text-align:center;">P</td>
                            <td style="border:1px solid #999;padding:3px 8px;text-align:right;">
                                <t t-esc="'{:,.2f}'.format(boq['construction_total'])"/>
                            </td>
                        </tr>
                    </table>

                    <!-- Amount in words -->
                    <div style="margin-top:8px;font-size:9.5px;">
                        <strong>Amount in words: </strong>_______________________________________________
                    </div>

                </div>
            </main>
        </t>
    </template>

    <template id="report_sale_boq">
        <t t-foreach="docs" t-as="doc">
            <t t-call="sale_boq_report.report_sale_boq_document"/>
        </t>
    </template>

</odoo>
